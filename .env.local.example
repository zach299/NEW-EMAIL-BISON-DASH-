# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# EmailBison
EMAILBISON_BASE_URL=https://api.emailbison.com
EMAILBISON_API_KEY=your_emailbison_api_key

# Webhook security
EMAILBISON_WEBHOOK_SECRET=your_webhook_signing_secret

# Manual sync trigger secret (used as a header: x-sync-secret)
SYNC_SECRET=your_manual_sync_secret
